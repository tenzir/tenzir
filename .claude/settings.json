{
  "permissions": {
    "allow": [
      "Skill(compile)",
      "Bash(ls:*)",
      "Bash(*/bin/tenzir-test)",
      "Bash(*/bin/tenzir-test *)",
      "Bash(uvx tenzir-test:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_TASK_LIST_ID": "tenzir-tenzir"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "tenzir": {
      "source": {
        "source": "github",
        "repo": "tenzir/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "dev@tenzir": true,
    "python@tenzir": true
  }
}
