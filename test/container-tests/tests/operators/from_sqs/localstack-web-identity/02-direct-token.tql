// Test from_sqs with web identity using direct token value.
// Uses AssumeRoleWithWebIdentity with a token provided directly.
// Each test uses its own queue to avoid message consumption conflicts.
from_sqs env("LOCALSTACK_SQS_QUEUE_WEB_IDENTITY_TOKEN"), aws_iam={
  region: "us-east-1",
  assume_role: env("LOCALSTACK_WEB_IDENTITY_ROLE_ARN"),
  web_identity: {
    token: env("LOCALSTACK_WEB_IDENTITY_TOKEN")
  }
}
head 3
this = message.parse_json()
sort id
