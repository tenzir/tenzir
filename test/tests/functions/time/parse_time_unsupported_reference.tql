from {
  week_without_year: "22 1",
  day_without_month: "5 18:16:21",
  month_with_invalid_reference_day: "Feb 12:00:00",
}

week_date_reference_year = week_without_year.parse_time(
  "%U %w",
  reference=2024-01-01T00:00:00Z,
)
invalid_reference_completed_date = month_with_invalid_reference_day.parse_time(
  "%b %H:%M:%S",
  reference=2026-01-31T00:00:00Z,
)
day_without_month_reference = day_without_month.parse_time(
  "%e %H:%M:%S",
  reference=2026-06-24T00:00:00Z,
)
