from (
  {label: "v4-24", addr: 10.10.1.124, text: "10.20.1.124", prefix: 24},
  {label: "v4-16", addr: 10.10.1.124, text: "10.20.1.124", prefix: 16},
  {label: "v6-64", addr: ip("2001:db8::1"), text: "2001:db8::1", prefix: 64},
)
select \
  label,
  from_ip = subnet(addr, prefix),
  from_string = subnet(text, prefix)
