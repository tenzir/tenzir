// Verify that a `secret`-typed value passed through `drop_null_fields` is not
// redacted. This is the central motivation for adding the function: it lets
// `from_http body=drop_null_fields({license: $license, ...})` strip null
// optional fields while still passing the secret license through to the API.
from {
  body: drop_null_fields({
    license: secret("license-token", _literal=true),
    version: 1,
    mapping: null
  })
}
license_type = type_of(body.license)
