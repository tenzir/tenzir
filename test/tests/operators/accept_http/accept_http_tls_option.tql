---
fixtures:
  - http:
      mode: client
      tls: true
      path: /tls
      body: '{"tls":true}'
timeout: 60
---

accept_http env("HTTP_FIXTURE_ACCEPT_ENDPOINT"),
            max_connections=16,
            tls={
              certfile: env("HTTP_FIXTURE_TLS_CERTFILE"),
              keyfile: env("HTTP_FIXTURE_TLS_KEYFILE"),
              skip_peer_verification: true,
            } {
  read_json
  where $request.path == "/tls"
}
head 1
