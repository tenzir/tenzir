---
fixtures:
  - http:
      mode: client
      path: /respond
      body: '{"answer":42}'
      expected_status: 201
      expected_response_body: pong
timeout: 60
---

accept_http env("HTTP_FIXTURE_ACCEPT_ENDPOINT"),
            max_connections=1,
            responses={
              "/respond": {
                code: 201,
                content_type: "text/plain",
                body: "pong",
              },
            } {
  read_json
  where $request.path == "/respond"
}
head 1
