---
fixtures:
  - http_request:
      requests:
        - path: /_bulk
          body: "{\"index\":{\"_index\":\"test\"}}\n{\"value\":42}\n"
          expected_status: 413
        - path: /_bulk
          body: "{\"index\":{}}\n{\"a\":1}\n"
timeout: 10
---

accept_opensearch env("HTTP_REQUEST_ENDPOINT"), max_request_size=30
head 1
