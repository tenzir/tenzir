from {team: "security", event: "scan"},
     {team: "infra", event: "deploy"}
repeat 500
enumerate id
to_google_cloud_logging log_id="folder-log",
                        folder="987654321",
                        payload=f"folder-{id}",
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
