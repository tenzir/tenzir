from {cost: 12.50, service: "compute"},
     {cost: 0.03, service: "storage"}
repeat 500
enumerate id
to_google_cloud_logging log_id="billing-log",
                        billing_account="ABC-123-DEF",
                        payload=f"billing-{id}",
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
