// Test that log_id with special characters is URL-encoded in log_name.
from {data: "test"},
     {data: "other"}
repeat 500
enumerate id
to_google_cloud_logging log_id="my/custom.log",
                        project="test-project",
                        payload=f"encoded-{id}",
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
