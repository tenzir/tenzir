// Send 1000 events where some resource label values are non-string.
// The operator should warn and skip the non-string labels, keeping valid ones.
from {msg: "test"},
     {msg: "other"}
repeat 500
enumerate id
to_google_cloud_logging log_id="bad-labels-log",
                        project="test-project",
                        payload=f"bad-label-{id}",
                        resource_labels={zone: "us-east1-b", count: 42},
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
