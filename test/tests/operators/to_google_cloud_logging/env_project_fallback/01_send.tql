// Send 1000 events without specifying project/organization/etc.
// The operator should fall back to GOOGLE_CLOUD_PROJECT env var
// (set to "test-project" by the fixture).
from {source: "app-server", level: "info"},
     {source: "db-proxy", level: "warning"}
repeat 500
enumerate id
to_google_cloud_logging log_id="env-fallback-log",
                        payload=f"env-fb-{id}",
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
