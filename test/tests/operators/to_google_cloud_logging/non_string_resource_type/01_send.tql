// Send 1000 events where resource_type is an integer (wrong type).
// Operator should warn and fall back to "global".
from {msg: "test", rt: 42},
     {msg: "other", rt: 99}
repeat 500
enumerate id
to_google_cloud_logging log_id="bad-rt-log",
                        project="test-project",
                        payload=f"bad-rt-{id}",
                        resource_type=rt,
                        service_credentials=file_contents(env("GCL_SERVICE_CREDENTIALS")),
                        batch_timeout=1s
