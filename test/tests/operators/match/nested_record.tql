from {src: {ip: 1.2.3.4, port: 12345}, alert: {severity: "high", id: "a"}},
     {src: {ip: 1.2.3.4}, alert: {severity: "low"}},
     {src: {ip: 5.6.7.8}, alert: {severity: "high"}}
match this {
  {src: {ip: 1.2.3.4, ..}, alert: {severity: "high", ..}, ..} => {
    verdict = "match"
  }
  {..} => {
    verdict = "other"
  }
}
sort verdict
