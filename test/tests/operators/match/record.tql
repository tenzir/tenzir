from {action: "allow", dst_port: 443, extra: true},
     {action: "allow", dst_port: 22, extra: true},
     {action: "deny", dst_port: 443},
     {action: "deny", extra: true},
     {}
match this {
  {action: "allow", dst_port: 443, ..} => {
    verdict = "web allow"
  }
  {action: "deny", dst_port: 443} => {
    verdict = "exact deny"
  }
  {} => {
    verdict = "empty"
  }
  {..} => {
    verdict = "other record"
  }
}
sort verdict
