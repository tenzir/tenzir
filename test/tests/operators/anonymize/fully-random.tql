from {
  i: 1,
  u: uint(2),
  d: 1.0,
  b: true,
  s: "x",
  addr: 10.0.0.1,
  net: 10.0.0.0/8,
  ts: 2025-01-15,
  dur: 5s,
  nested: {
    x: 1,
    y: "z",
  },
  items: [1, 2, 3],
}
anonymize seed=1, sample=1, count=2, fully_random=true
// Unfortunately we cannot rely on seeded output here, as the C++ standard in it's
// infinite wisdom chose to only standardize generators, but not distributions.
// Hence the output can vary here between different libc++ and libstdc++ and every
// different versions thereof.
assert type_id(i) == type_id(0)
assert type_id(u) == type_id(uint(0))
assert type_id(d) == type_id(0.0)
assert type_id(b) == type_id(false)
assert type_id(s) == type_id("")
assert type_id(addr) == type_id(0.0.0.0)
assert type_id(net) == type_id(0.0.0.0/0)
assert type_id(ts) == type_id(1970-01-01)
assert type_id(dur) == type_id(0s)
assert type_id(nested.x) == type_id(0)
assert type_id(nested.y) == type_id("")
assert type_id(items) == type_id([0])
summarize count=count(this)
