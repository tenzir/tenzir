from_amazon_cloudwatch env("LOCALSTACK_CLOUDWATCH_LOG_GROUP"),
  mode="filter",
  log_streams=[env("LOCALSTACK_CLOUDWATCH_LOG_STREAM_FILTER")],
  filter="ERROR",
  aws_iam={
    access_key_id: "test",
    secret_access_key: "test",
    region: "us-east-1",
  }
this = message.parse_json()
select id, level, msg
sort id
