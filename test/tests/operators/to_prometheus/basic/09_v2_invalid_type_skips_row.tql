from {
  metric: "v2_invalid_type",
  value: 10,
  timestamp: 2026-05-15T10:00:15Z,
  type: "guage",
}, {
  metric: "v2_valid_after_invalid_type",
  value: 11,
  timestamp: 2026-05-15T10:00:16Z,
}
to_prometheus env("PROMETHEUS_REMOTE_WRITE_URL"),
              protobuf_message="io.prometheus.write.v2.Request",
              flush_interval=10s,
              max_samples_per_request=100
