from {
  metric: "v2_metadata_merge",
  value: 8,
  timestamp: 2026-05-15T10:00:13Z,
  labels: {
    instance: "a",
  },
}, {
  metric: "v2_metadata_merge",
  value: 9,
  timestamp: 2026-05-15T10:00:14Z,
  labels: {
    instance: "a",
  },
  type: "gauge",
  help: "Merged metadata",
  unit: "items",
}
to_prometheus env("PROMETHEUS_REMOTE_WRITE_URL"),
              protobuf_message="io.prometheus.write.v2.Request",
              flush_interval=10s,
              max_samples_per_request=100
