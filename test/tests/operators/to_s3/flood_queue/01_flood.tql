// Stress the single-partition shutdown path via S3 multipart uploads.
//
// Arrow's S3 OutputStream uses multipart upload: `Close()` sends
// `CompleteMultipartUpload`, and without it the upload is abandoned and
// no object appears in the bucket. A single output file with 5000 large
// events produces many chunks that back up in the sub's input channel;
// when `finalize()` closes the sub and the executor begins shutdown,
// the final `close_stream` must still run or the multipart upload is
// left pending on the server.
from {padding: "x".repeat(256)}
repeat 5000
enumerate seq
to_s3 env("S3_BUCKET") + "/flood_test/output.json?endpoint_override=" + env("S3_ENDPOINT") + "&scheme=http", aws_iam={access_key_id: env("S3_ACCESS_KEY"), secret_access_key: env("S3_SECRET_KEY")} {
  write_ndjson
}
