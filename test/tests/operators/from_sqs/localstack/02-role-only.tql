// Test from_sqs with role-only authentication.
// Uses the default credential chain (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY
// from environment) to assume a role, then reads from SQS.
// Each test uses its own queue to avoid message consumption conflicts.
from_sqs env("LOCALSTACK_SQS_QUEUE_ROLE"), aws_iam={
  region: "us-east-1",
  assume_role: env("LOCALSTACK_ROLE_ARN"),
  external_id: env("LOCALSTACK_EXTERNAL_ID")
}
head 3
this = message.parse_json()
sort id
