---
error: true
---

// The target topic caps `max.message.bytes` at 1 KB (see test.yaml). The client
// `message.max.bytes` is raised far above that, so this ~2 KB event passes
// librdkafka's local size check and is only rejected asynchronously by the
// broker. That broker-side delivery failure must abort the pipeline with a
// diagnostic instead of being dropped silently.
from {data: ""}
to_kafka env("KAFKA_TOPIC"),
         options={
           "bootstrap.servers": env("KAFKA_BOOTSTRAP_SERVERS"),
           "message.max.bytes": "10000000"
         }
