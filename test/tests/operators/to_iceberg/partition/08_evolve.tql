// Schema evolution on a partitioned table: the severity column is new, and
// the first event carries no time at all, landing in a null partition.
from {class_uid: 1001, msg: "g"},
     {class_uid: 1001, time: 2026-01-03T10:00:00Z, msg: "h", severity: 3}
to_iceberg "partns.events", catalog=env("ICEBERG_REST_URI")
