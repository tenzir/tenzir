// Create a partitioned table: identity on class_uid plus a daily time
// bucket. Hidden partitioning: no helper column appears in the schema, and
// rows fan out into one data file per partition tuple.
from {class_uid: 1001, time: 2026-01-01T10:00:00Z, msg: "a"},
     {class_uid: 1001, time: 2026-01-01T11:00:00Z, msg: "b"},
     {class_uid: 1001, time: 2026-01-02T10:00:00Z, msg: "c"},
     {class_uid: 4001, time: 2026-01-01T10:30:00Z, msg: "d"}
to_iceberg "partns.events", catalog=env("ICEBERG_REST_URI"),
  partition_by=[class_uid, day(time)]
