// Create the table from the first slice's schema: records stay nested
// structs, ip and subnet map to strings, time maps to microsecond
// timestamptz and registers the sort order, duration maps to nanosecond
// counts.
from {id: 1, time: 2026-01-01T00:00:00Z, src_ip: 192.168.0.1, net: 10.0.0.0/8, dur: 90s, meta: {level: "info", tags: ["a", "b"]}},
     {id: 2, time: 2026-01-01T00:00:01Z, src_ip: ::1, net: 192.168.0.0/16, dur: 1ms, meta: {level: "warn", tags: []}}
to_iceberg "createns.events", catalog=env("ICEBERG_REST_URI")
