---
fixtures:
  - http:
      tls: true
      expected_request:
        count: 1
        method: POST
        path: /options/body
        body: |-
          {
            "tls": "ok"
          }
timeout: 60
---

from {
  foo: "bar",
}
to_http env("HTTP_FIXTURE_BODY_URL"),
        method="post",
        body={tls: "ok"},
        tls={skip_peer_verification: true}
