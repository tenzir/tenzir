---
fixtures: [sentinelone]
timeout: 60
---

// Same server response as typed_strings.tql, but raw=true disables the
// non_number_parser so every string value stays as a plain string regardless
// of whether it looks like an IP address or subnet.
from_sentinelone_data_lake env("S1_FIXTURE_URL"),
  token=secret("test-token-s1-12345", _literal=true),
  query="select_typed_strings",
  raw=true
