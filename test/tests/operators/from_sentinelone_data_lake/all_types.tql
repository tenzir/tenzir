---
fixtures: [sentinelone]
timeout: 60
---

// Exercises every branch of parse(): null, bool, int64 (negative), uint64
// (> INT64_MAX so simdjson classifies it as uint64_t), double, and string.
// The "timestamp" column is handled by the dedicated nanosecond→time path.
from_sentinelone_data_lake env("S1_FIXTURE_URL"),
  token=secret("test-token-s1-12345", _literal=true),
  query="select_all_types"
