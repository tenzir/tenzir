---
error: true
---

// String value for skip_peer_verification (expects bool) should produce an error
from_mysql sql="SELECT 1",
           host=env("MYSQL_HOST"),
           port=int(env("MYSQL_PORT")),
           user=env("MYSQL_USER"),
           password=env("MYSQL_PASSWORD"),
           database=env("MYSQL_DATABASE"),
           tls={skip_peer_verification: "yes"}
