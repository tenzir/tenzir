// Reset mode: aggregation resets after each emission.
// Schedule events so the timer fires between them.
from {ts: 0ms.from_epoch(), x: 1},
     {ts: 5ms.from_epoch(), x: 1},
     {ts: 12ms.from_epoch(), x: 1},
     {ts: 22ms.from_epoch(), x: 1}
delay ts
summarize {frequency: 10ms}, count=count()
