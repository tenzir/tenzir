---
fixtures:
- http_server:
    expected:
    - method: POST
      path: /services/search/v2/jobs/export
      body: search=fixture&earliest_time=-15m&latest_time=-5m&output_mode=json&preview=false
      header_name: Authorization
      header_value: Splunk test-token
---

from_splunk env("HTTP_FIXTURE_URL"),
  search="fixture",
  earliest="-15m",
  latest="-5m",
  headers={
    Authorization: secret("Splunk test-token", _literal=true),
  },
  tls=false
