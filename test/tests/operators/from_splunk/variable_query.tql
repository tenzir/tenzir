---
fixtures:
  - http_server:
      expected:
        - method: POST
          path: /services/search/v2/jobs/export
          body: search=search%20index%3Dmain%20user%3D%22Jane%20Doe%22&earliest_time=-15m&latest_time=-5m&output_mode=json&preview=false
---

let $index = "main"
let $user = "Jane Doe"

from_splunk env("HTTP_FIXTURE_URL"),
  search=f"search index={$index} user=\"{$user}\"",
  earliest="-15m",
  latest="-5m",
  headers={Authorization: "Splunk test-token"},
  tls=false
