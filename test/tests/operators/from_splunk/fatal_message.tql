---
fixtures:
  - http_server:
      expected:
        - method: POST
          path: /splunk/fatal-message/services/search/v2/jobs/export
          body: search=%7C%20rest%20%2Fservices%2Fmissing&earliest_time=-15m&latest_time=-5m&output_mode=json&preview=false
error: true
---

from_splunk env("HTTP_FIXTURE_SPLUNK_FATAL_MESSAGE_URL"),
  search="| rest /services/missing",
  earliest="-15m",
  latest="-5m",
  headers={Authorization: "Splunk test-token"},
  tls=false
