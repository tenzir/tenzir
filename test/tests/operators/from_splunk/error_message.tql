---
fixtures:
  - http_server:
      expected:
        - method: POST
          path: /splunk/error-message/services/search/v2/jobs/export
          body: search=%7C%20inputlookup%20%22missing%20lookup.csv%22&earliest_time=-15m&latest_time=-5m&output_mode=json&preview=false
error: true
---

from_splunk env("HTTP_FIXTURE_SPLUNK_ERROR_MESSAGE_URL"),
  search=r#"| inputlookup "missing lookup.csv""#,
  earliest="-15m",
  latest="-5m",
  headers={Authorization: "Splunk test-token"},
  tls=false
