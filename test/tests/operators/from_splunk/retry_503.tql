---
fixtures:
- http_server:
    expected:
    - count: 3
      method: POST
      path: /splunk/retry-503/services/search/v2/jobs/export
timeout: 60
---

from_splunk env("HTTP_FIXTURE_SPLUNK_RETRY_503_URL"),
  search="fixture",
  earliest="-15m",
  latest="-5m",
  headers={Authorization: "Splunk test-token"},
  tls=false,
  max_retry_count=2,
  retry_delay=1ms
