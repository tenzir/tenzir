---
assertions:
  fixtures:
    splunk:
      count: 1
      source: tenzir-test-include-nulls
      sourcetype: tenzir:test:nulls
      contains:
        - optional
---

from {message: "include-nulls", optional: null.string()}
to_splunk env("SPLUNK_HEC_URL"),
          hec_token=env("SPLUNK_HEC_TOKEN"),
          source="tenzir-test-include-nulls",
          sourcetype="tenzir:test:nulls",
          index=env("SPLUNK_INDEX"),
          include_nulls=true,
          compress=false
