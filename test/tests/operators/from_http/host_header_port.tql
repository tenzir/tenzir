---
fixtures: [http_server]
timeout: 60
---

// Regression test: the Host header must include the port for non-standard
// ports. CAF's HTTP client used to omit the port, breaking servers that
// validate the Host header (e.g. for pre-signed URL signature verification).
from_http env("HTTP_FIXTURE_HOST_URL"), tls=false {
  read_json
}
this.host = replace_regex(this.host, r"127\.0\.0\.1:\d+", "127.0.0.1:<port>")
