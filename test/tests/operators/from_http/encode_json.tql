---
fixtures:
  - http_server:
      expected_request:
        header_name: Content-Type
        header_value: application/json
timeout: 60
---

from_http env("HTTP_FIXTURE_BODY_URL"),
          method="post",
          body={a: "hello", b: "world"},
          encode="json",
          tls=false {
  read_json
}
