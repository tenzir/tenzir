// Tumbling windows: each event belongs to exactly one 2s window, and the
// window metadata is exposed via `$window`.
from {ts: 0s.from_epoch()},
     {ts: 1s.from_epoch()},
     {ts: 2s.from_epoch()},
     {ts: 3s.from_epoch()},
     {ts: 4s.from_epoch()}
window size=2s, on=ts {
  summarize n=count()
  start = $window.start.since_epoch()
  end = $window.end.since_epoch()
}
sort start
