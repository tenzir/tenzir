let $wanted_subject = "from_nats_read_lines_let_test"
from_nats env("NATS_SUBJECT"),
          url=env("NATS_URL"),
          durable=env("NATS_DURABLE"),
          count=1,
          metadata_field=nats
where nats.subject == $wanted_subject
line = string(message)
subject = nats.subject
select line, subject
