// Test ocsf::derive with DNS answer flag_ids after a class/version split.
// This verifies list enum derivation for sliced Arrow list arrays.

from {
  metadata: {
    version: "1.6.0",
  },
  class_uid: 4003,  // DNS Activity
  activity_id: 2,   // Response
  answers: [],
}, {
  metadata: {
    version: "1.5.0",
  },
  class_uid: 4003,  // DNS Activity
  activity_id: 2,   // Response
  answers: [
    {
      rdata: "192.168.1.1",
      flag_ids: [1, 3, 4],
      ttl: 300,
    },
  ],
}
ocsf::derive
