// Creates a multiserve session seeded with two serve ids and polls it in a
// single request. The server assigns a random `multiserve_id`, so we hoist the
// `results` map to the top level (dropping the id) to keep the output
// deterministic; the per-serve objects then match the /serve-multi response.
api "/multiserve", {
  serve_ids: [
    {serve_id: "multiserve_1"},
    {serve_id: "multiserve_2"},
  ],
  timeout: 5s,
  min_events: 8,
  max_events: 8,
  schema: "never",
}
this = results
responses = [
  {id: "multiserve_1", response: multiserve_1},
  {id: "multiserve_2", response: multiserve_2},
]
unroll responses
this = responses
unroll response.events
data = response.events.data
select id, data
to_stdout {
  write_tql
}
