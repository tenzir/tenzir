// Per-pipeline `schema` override: the request-wide default is `never`, but
// serve_multi_1 overrides it with `exact`, so only its response carries schema
// definitions.
api "/serve-multi", {
  requests: [
    {serve_id: "serve_multi_1", schema: "exact"},
    {serve_id: "serve_multi_2"},
  ],
  timeout: 5s,
  min_events: 8,
  max_events: 8,
  schema: "never",
}
responses = [
  {id: "serve_multi_1", response: serve_multi_1},
  {id: "serve_multi_2", response: serve_multi_2},
]
unroll responses
this = responses
has_schemas = response.has("schemas") and response.schemas.length() > 0
select id, has_schemas
sort id
to_stdout {
  write_tql
}
