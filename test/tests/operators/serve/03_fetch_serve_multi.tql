api "/serve-multi", {
  requests: [
    {
      serve_id: "serve_multi_1",
      continuation_token: "00000000-0000-0000-0000-000000000000",
    },
    {
      serve_id: "serve_multi_2",
      continuation_token: "00000000-0000-0000-0000-000000000000",
    },
  ],
  timeout: 5s,
  min_events: 8,
  max_events: 8,
  schema: "never",
}
responses = [
  {id: "serve_multi_1", response: serve_multi_1},
  {id: "serve_multi_2", response: serve_multi_2},
]
unroll responses
this = responses
unroll response.events
data = response.events.data
select id, data
to_stdout {
  write_tql
}
