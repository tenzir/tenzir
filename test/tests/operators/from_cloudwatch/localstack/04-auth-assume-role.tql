from_cloudwatch env("LOCALSTACK_CLOUDWATCH_LOG_GROUP"),
  mode="filter",
  log_streams=[env("LOCALSTACK_CLOUDWATCH_LOG_STREAM_FILTER")],
  filter="ERROR",
  aws_iam={
    region: "us-east-1",
    assume_role: env("LOCALSTACK_CLOUDWATCH_ROLE_ARN"),
    external_id: env("LOCALSTACK_CLOUDWATCH_EXTERNAL_ID"),
  }
this = message.parse_json()
select id, level, msg
