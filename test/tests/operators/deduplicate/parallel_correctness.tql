// Correctness of hash-partitioned parallel dedup: with many duplicates
// spread across many keys, we must still see each key exactly once.
from {k: 0}, {k: 1}, {k: 2}, {k: 3}, {k: 4},
     {k: 5}, {k: 6}, {k: 7}, {k: 8}, {k: 9},
     {k: 0}, {k: 1}, {k: 2}, {k: 3}, {k: 4},
     {k: 5}, {k: 6}, {k: 7}, {k: 8}, {k: 9},
     {k: 0}, {k: 1}, {k: 2}, {k: 3}, {k: 4},
     {k: 5}, {k: 6}, {k: 7}, {k: 8}, {k: 9}
deduplicate k
summarize c=count()
