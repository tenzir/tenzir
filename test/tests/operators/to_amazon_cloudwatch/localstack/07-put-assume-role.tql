from {message: "cw-role"}
to_amazon_cloudwatch env("LOCALSTACK_CLOUDWATCH_LOG_GROUP"),
  stream=env("LOCALSTACK_CLOUDWATCH_LOG_STREAM_WRITE"),
  payload=message,
  aws_iam={
    assume_role: env("LOCALSTACK_CLOUDWATCH_ROLE_ARN"),
    external_id: env("LOCALSTACK_CLOUDWATCH_EXTERNAL_ID"),
    region: "us-east-1",
  }

