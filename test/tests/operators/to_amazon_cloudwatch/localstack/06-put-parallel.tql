from {message: "cw-parallel-1"},
     {message: "cw-parallel-2"},
     {message: "cw-parallel-3"},
     {message: "cw-parallel-4"}
to_amazon_cloudwatch env("LOCALSTACK_CLOUDWATCH_LOG_GROUP"),
  env("LOCALSTACK_CLOUDWATCH_LOG_STREAM_WRITE"),
  message=message,
  batch_size=1,
  parallel=2,
  aws_region="us-east-1"

