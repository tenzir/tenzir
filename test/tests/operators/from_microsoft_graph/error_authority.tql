---
error: true
fixtures: [microsoft_graph]
timeout: 60
skip:
  on: fixture-unavailable
---

from_microsoft_graph "users",
  auth={
    tenant_id: env("MS_GRAPH_FIXTURE_TENANT_ID"),
    client_id: env("MS_GRAPH_FIXTURE_CLIENT_ID"),
    client_secret: env("MS_GRAPH_FIXTURE_CLIENT_SECRET"),
    authority: "login.microsoftonline.com",
  },
  _base_url=env("MS_GRAPH_FIXTURE_BASE_URL_V1")
