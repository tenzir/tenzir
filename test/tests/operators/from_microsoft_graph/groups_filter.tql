---
fixtures: [microsoft_graph]
timeout: 60
---

from_microsoft_graph "groups",
  auth={
    tenant_id: env("MS_GRAPH_FIXTURE_TENANT_ID"),
    client_id: env("MS_GRAPH_FIXTURE_CLIENT_ID"),
    client_secret: env("MS_GRAPH_FIXTURE_CLIENT_SECRET"),
    authority: env("MS_GRAPH_FIXTURE_AUTHORITY"),
  },
  odata={filter: "securityEnabled eq true"},
  tls={cacert: env("MS_GRAPH_FIXTURE_TLS_CACERT")}
