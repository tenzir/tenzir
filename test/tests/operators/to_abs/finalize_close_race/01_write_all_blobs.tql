// Write many partitions through a slow ABS proxy. This widens the shutdown
// window enough to catch races where partition streams are cancelled before
// their final block gets committed.
from {
  padding: ""
}
repeat 2048
enumerate pk
to_azure_blob_storage "abfs://" + env("ABS_ACCOUNT_NAME") + "@" + env("ABS_ENDPOINT")
                    + "/" + env("ABS_CONTAINER") + "/race/**/part_{uuid}.json?enable_tls=false",
                    account_key=env("ABS_ACCOUNT_KEY"),
                    partition_by=[pk] {
  write_ndjson
}
