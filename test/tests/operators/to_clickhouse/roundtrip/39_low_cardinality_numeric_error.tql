---
error: true
---

// `LowCardinality` is only supported for string columns; a numeric inner type
// is rejected with a clear error.
from {id: 0, code: 42}
to_clickhouse table="test_lc_numeric",
              host=env("CLICKHOUSE_HOST"),
              port=int(env("CLICKHOUSE_PORT")),
              password=env("CLICKHOUSE_PASSWORD"),
              tls=false,
              primary=id,
              mode="create",
              low_cardinality=code
