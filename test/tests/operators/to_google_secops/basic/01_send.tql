from {text: "hello world", type: "WINEVTLOG", ns: "test-ns"},
     {text: "second event", type: "WINEVTLOG", ns: "test-ns"},
     {text: "other type", type: "OKTA", ns: "test-ns"}
to_google_secops project="test-project",
                 region="us",
                 instance="test-instance",
                 log_text=text,
                 log_type=type,
                 namespace=ns,
                 log_entry_time=2026-01-01T00:00:00,
                 collection_time=2026-01-01T00:00:01,
                 labels={env: "test", tenant: {value: "acme", rbac_enabled: true}},
                 forwarder="test-forwarder",
                 hint="test-hint",
                 source_filename="test-source.log",
                 service_credentials=env("GOOGLE_SECOPS_SERVICE_CREDENTIALS"),
                 _ingestion_url=env("GOOGLE_SECOPS_INGESTION_URL"),
                 batch_timeout=1s
