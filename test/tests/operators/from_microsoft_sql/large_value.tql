from_microsoft_sql sql="SELECT id, CAST(payload AS VARCHAR(8000)) AS payload FROM dbo.large_values",
                   host=env("MSSQL_HOST"),
                   port=int(env("MSSQL_PORT")),
                   user=env("MSSQL_USER"),
                   password=env("MSSQL_PASSWORD"),
                   database=env("MSSQL_DATABASE")
