from_microsoft_sql query="SELECT COUNT(*) AS user_count FROM dbo.users",
                   host=env("MSSQL_HOST"),
                   port=int(env("MSSQL_PORT")),
                   user=env("MSSQL_USER"),
                   password=secret(env("MSSQL_PASSWORD"), _literal=true),
                   database=env("MSSQL_DATABASE")
