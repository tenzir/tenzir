from_microsoft_sql sql="SELECT CAST(N'Grüße 𐐷' AS NVARCHAR(100)) AS value",
                   host=env("MSSQL_HOST"),
                   port=int(env("MSSQL_PORT")),
                   user=env("MSSQL_USER"),
                   password=env("MSSQL_PASSWORD"),
                   database=env("MSSQL_DATABASE")
