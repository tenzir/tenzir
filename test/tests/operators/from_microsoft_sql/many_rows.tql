from_microsoft_sql sql="SELECT id FROM dbo.many_rows ORDER BY id",
                   host=env("MSSQL_HOST"),
                   port=int(env("MSSQL_PORT")),
                   user=env("MSSQL_USER"),
                   password=env("MSSQL_PASSWORD"),
                   database=env("MSSQL_DATABASE")
| summarize rows=count(), min_id=min(id), max_id=max(id)
