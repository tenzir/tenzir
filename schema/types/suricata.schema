}

type suricata.ike = suricata.component.common + record {
  tx_id: uint64 #index=hash,
  ike: record {
    version_major: uint64,
    version_minor: uint64,
    init_spi: string,
    resp_spi: string,
    message_id: uint64,
    exchange_type: uint64,
    exchange_type_verbose: string,
    sa_life_type: string,
    sa_life_type_raw: uint64,
    sa_life_duration: string,
    sa_life_duration_raw: uint64,
    alg_enc: string,
    alg_enc_raw: uint64,
    alg_hash: string,
    alg_hash_raw: uint64,
    alg_auth: string,
    alg_auth_raw: uint64,
    alg_dh: string,
    alg_dh_raw: uint64,
    sa_key_length: string,
    sa_key_length_raw: uint64,
    alg_esn: string,
    alg_esn_raw: uint64,
    payload: list<string>,
    server_proposals: list<suricata.ike_proposal>,
    ikev1: record {
      doi: uint64,
      encrypted_payloads: bool,
      client: record {
        key_exchange_payload: string,
        key_exchange_payload_length: uint64,
        nonce_payload: string,
        nonce_payload_length: uint64,
        proposals: list<suricata.ike_proposal>
      },
      server: record {
        key_exchange_payload: string,
        key_exchange_payload_length: uint64,
        nonce_payload: string,
        nonce_payload_length: uint64
      },
      vendor_ids: list<string>
    },
    ikev2: record {
      role: string,
      errors: uint64,
      notify: list<string>
    }
  }
}

