    filename: string #index=hash,
    command: string  #index=hash
  }
}

type suricata.http = suricata.component.common + record {
  http: record {
    hostname: string,
    url: string,
    http_port: uint64,
    http_user_agent: string,
    http_content_type: string,
    http_method: string,
    http_refer: string,
    protocol: string,
    status: uint64,
    redirect: string,
    length: uint64
  },
  tx_id: uint64 #index=hash
}

