type suricata.tls = suricata.component.common + record {
  tls: record {
    certificate: string,
    chain: list<string>,
    client: record {
      certificate: string,
      chain: list<string>,
      fingerprint: string,
      issuerdn: string,
      notafter: time,
      notbefore: time,
      serial: string,
      subject: string,
      subjectaltname: list<string>
    },
    client_alpns: list<string>,
    client_handshake: record {
      ciphers: list<uint64>,
      exts: list<uint64>,
      sig_algs: list<uint64>,
      version: string
    },
    from_proto: string,
    sni: string,
    session_resumed: bool,
    subject: string,
    subjectaltname: list<string>,
    issuerdn: string,
    serial: string,
    fingerprint: string,
    ja3: suricata.component.ja3,
    ja3s: suricata.component.ja3,
    ja4: string,
    ja4s: string,
    server_alpns: list<string>,
    server_handshake: record {
      cipher: uint64,
      exts: list<uint64>,
      version: string
    },
    notbefore: time,
    notafter: time
  }
}

type suricata.stats = record {
  timestamp: time
}

type suricata.websocket = suricata.component.common + record {
  websocket: record {
    fin: bool,
    mask: uint64,
    opcode: string,
    payload_base64: string,
    payload_printable: string
  }
}
