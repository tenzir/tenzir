---
bench:
  id: kinesis-json
  description: Acquire the Route53 sample payload from mock Kinesis and parse it as JSON.
---
from_amazon_kinesis f"{env("BENCHMARK_KINESIS_STREAM")}",
  start="trim_horizon",
  count=258600,
  exit=true,
  endpoint=f"{env("BENCHMARK_KINESIS_ENDPOINT")}",
  aws_iam={access_key_id: "bench", secret_access_key: "bench", region: "us-east-1"}
this = string(message).parse_json()
discard
