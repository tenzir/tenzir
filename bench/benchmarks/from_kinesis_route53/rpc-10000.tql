---
bench:
  id: kinesis-rpc-10000
  description: Acquire the Route53 sample payload from mock Kinesis with maximum records per call.
---
from_amazon_kinesis f"{env("BENCHMARK_KINESIS_STREAM")}",
  start="trim_horizon",
  count=258600,
  exit=true,
  records_per_call=10000,
  endpoint=f"{env("BENCHMARK_KINESIS_ENDPOINT")}",
  aws_iam={access_key_id: "bench", secret_access_key: "bench", region: "us-east-1"}
discard
